@{
    ViewData["Title"] = "Latest DfE Publications";
}
@model SchoolAccount.Alpha.ViewModels.ContentViewModel

<h2 class="govuk-heading-m">@Model.PageTitle (page @Model.CurrentPage of @Model.TotalPages)</h2>
<ul class="govuk-task-list">
    @foreach (var result in Model.Results)
    {
        <li class="govuk-task-list__item govuk-task-list__item--with-link">
            <div class="govuk-task-list__name-and-hint">
                <a class="govuk-link govuk-task-list__link"
                   href="https://www.gov.uk/@result.Link"
                   target="_blank"
                   rel="noopener noreferrer">
                    @result.Title
                </a>
                <div class="govuk-task-list__hint">
                    <p class="govuk-body">@result.Description</p>
                </div>
                <div class="govuk-task-list__hint">
                    <strong>Format:</strong> @result.Format
                </div>
                @* <details class="govuk-details">
                    <summary class="govuk-details__summary">
                        <span class="govuk-details__summary-text">
                            Indexed Content
                        </span>
                    </summary>
                    <div class="govuk-details__text">
                        @Html.Raw(result.IndexableContent.Replace("\n", "<br/>"))
                    </div>
                </details> *@
                @if (result.StartDate.HasValue)
                {

                    <div class="govuk-task-list__hint">
                        <strong>Start Date:</strong> @result.StartDate?.ToString("dd/MM/yyyy")
                    </div>
                }
                    @if (result.EndDate.HasValue)
                {

                    <div class="govuk-task-list__hint">
                        <strong>End Date:</strong> @result.EndDate?.ToString("dd/MM/yyyy")
                    </div>
                }
                @if (result.Taxons.Count > 0)
                {
                    <div class="govuk-task-list__hint">
                        <strong>Taxonomy:</strong> @string.Join(", ", result.Taxons)
                    </div>
                }
                @if (result.PartOfTaxonomyTree.Count > 0)
                {
                    <div class="govuk-task-list__hint">
                        <strong>Taxonomy tree:</strong> @string.Join("->", result.PartOfTaxonomyTree)
                    </div>
                }

            </div>
            <div class="govuk-task-list__status">
                Updated @result.UpdatedAt
            </div>
        </li>
    }
</ul>

<govuk-pagination>
    @if (Model.CurrentPage > 1)
    {
        <govuk-pagination-previous display="" href="@Url.Action(Model.Action, new { pageNo = Model.CurrentPage - 1, query = Model.Query })" />
    }
    <govuk-pagination-item href="#" current="true">@Model.CurrentPage</govuk-pagination-item>
    @if (Model.CurrentPage < Model.TotalPages)
    {
        <govuk-pagination-next href="@Url.Action(Model.Action, new { pageNo = Model.CurrentPage + 1, query = Model.Query })" />
    }
</govuk-pagination>